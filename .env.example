# DogeOS Scroll SDK CLI environment example.
#
# Keep real values in .env.local or another ignored env file.
# `scrollsdk setup generate-from-spec` loads .env.local/.env next to the spec
# file and in the current directory, or you can pass `--env-file`.
#
# This file contains private inputs that generate-from-spec needs. EVM service
# private keys, sequencer node keys, coordinator JWT, service database passwords,
# TEE keys, and CubeSigner roles are generated by setup commands.
# AWS and CubeSigner login credentials are intentionally not listed here; log in
# with each provider's own tooling before running the relevant CLI command.

# Database admin password for setup db-init. Service database users/passwords
# are generated by db-init because the database names are fixed by the spec.
DB_ADMIN_PASSWORD=replace-with-db-admin-password

# Public owner/admin EVM address. This is not secret, but keeping it here lets
# minimal specs stay reusable across deployments.
OWNER_ADDRESS=0x0000000000000000000000000000000000000e01

# External Dogecoin RPC credentials used by the CLI and bridge setup.
DOGECOIN_EXTERNAL_RPC_USERNAME=replace-with-external-dogecoin-rpc-username
DOGECOIN_EXTERNAL_RPC_PASSWORD=replace-with-external-dogecoin-rpc-password

# K8s-internal Dogecoin Core RPC credentials. The internal URL is fixed by
# dogecoin.network and the chart service name, not by this env file.
DOGECOIN_CLUSTER_RPC_USERNAME=replace-with-cluster-dogecoin-rpc-username
DOGECOIN_CLUSTER_RPC_PASSWORD=replace-with-cluster-dogecoin-rpc-password

# Optional Blockbook API key if your Blockbook provider requires one.
DOGECOIN_BLOCKBOOK_API_KEY=
